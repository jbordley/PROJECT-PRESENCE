# ── Sentinel Runtime Environment ──────────────────────────────────
# Copy this to .env and fill in your real values.
# .env is .gitignore'd and will not be committed.

# MQTT broker IP
MQTT_HOST=192.168.1.X
MQTT_PORT=1883

# Config file location
SENTINEL_CONFIG=/home/YOUR_USER/Presence/sentinel_config.json

# Python path
PYTHONPATH=/home/YOUR_USER/Presence

# Working directory
SENTINEL_WORKDIR=/home/YOUR_USER/Presence

# Logging
LOG_LEVEL=INFO

# Camera adapter specifics
CAMERA_ZONE=office
THERMAL_DEVICE=1
THERMAL_CROP=auto
SNAPSHOT_PORT=8089

# Dashboard
DASHBOARD_PORT=8080
